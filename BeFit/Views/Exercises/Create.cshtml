@model BeFit.Models.Exercise

@{
    ViewData["Title"] = "Create";
}

@if (ViewBag.SessionDate != null)
{
    <h1 class="text-primary mt-3">Dodawanie ćwiczenia do sesji:</h1>
    <h5 class="text-muted mb-4">@ViewBag.SessionDate</h5>
}
else
{
    <h1>Create</h1>
    <h4>Exercise</h4>
}

<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type ="hidden" asp-for="SessionId" value="@ViewBag.CurrentSessionId" />
            <div class="form-group">
                <label asp-for="ExerciseTypeId" class="control-label"></label>
                <select asp-for="ExerciseTypeId" class="form-control" asp-items="ViewBag.ExerciseTypeId"></select>
            </div>
            <div class="form-group">
                <label asp-for="Weight" class="control-label"></label>
                <input asp-for="Weight" class="form-control" />
                <span asp-validation-for="Weight" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="NumOfSeries" class="control-label"></label>
                <input asp-for="NumOfSeries" class="form-control" />
                <span asp-validation-for="NumOfSeries" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="NumOfReps" class="control-label"></label>
                <input asp-for="NumOfReps" class="form-control" />
                <span asp-validation-for="NumOfReps" class="text-danger"></span>
            </div>
            <br>
            <div class="form-group">
                <input type="submit" value="Dodaj" class="btn btn-primary" />
                <a asp-action="Index" asp-route-sessionId="@ViewBag.CurrentSessionId" class="btn btn-secondary">Wróć do listy ćwiczeń tej sesji</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
