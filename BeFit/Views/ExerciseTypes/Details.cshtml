@model BeFit.Models.ExerciseType

@{
    ViewData["Title"] = "Details";
}

<h1>@Html.DisplayFor(model => model.Name)</h1>

<div>
    <hr />
    <dl class="row">
        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <br>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.Description)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.Description)
            </dd>
        }
        else
        {
            <span>Brak opisu</span>
        }
    </dl>
</div>
<div>
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-primary">Edytuj</a>
        <a asp-action="Index" class="btn btn-secondary">Powrót do listy ćwiczeń</a>
    }
    else
    {
        <a asp-action="Index" class="btn btn-primary">Powrót do listy ćwiczeń</a>
    }

</div>
